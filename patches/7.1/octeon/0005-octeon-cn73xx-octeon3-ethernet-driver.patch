+int set_eth_pwr(int bgx, int index, int speed, int on_off)
+{
+	int port = bgx * 4 + index;
+
+	if(port == 10)
+		port = 8;
+	
+	set_serdes_eie_detection(port, on_off);
+	set_pcs_power(port, speed ,on_off);
+	
+	return 0;
+}	
