+/*
+
+ First buffer:
+
+                              +---SKB---------+
+                              |               |
+                              |               |
+                           +--+--*data        |
+                           |  |               |
+                           |  |               |
+                           |  +---------------+
+                           |       /|\
+                           |        |
+                           |        |
+                          \|/       |
+  WQE - 128 --+-----> +-------------+-------+     -+-
+              |       |    *skb ----+       |      |
+              |       |                     |      |
+              |       |                     |      |
+    WQE_SKIP = 128    |                     |      |
+              |       |                     |      |
+              |       |                     |      |
+              |       |                     |      |
+              |       |                     |      First Skip
+  WQE    -----+-----> +---------------------+      |
+                      |   word 0            |      |
+                      |   word 1            |      |
+                      |   word 2            |      |
+                      |   word 3            |      |
+                      |   word 4            |      |
+                      +---------------------+     -+-
+                 +----+- packet link        |
+                 |    |  packet data        |
+                 |    |                     |
+                 |    |                     |
+                 |    |         .           |
+                 |    |         .           |
+                 |    |         .           |
+                 |    +---------------------+
+                 |
+                 |
+ Later buffers:  |
+                 |
+                 |
+                 |
+                 |
+                 |
+                 |            +---SKB---------+
+                 |            |               |
+                 |            |               |
+                 |         +--+--*data        |
+                 |         |  |               |
+                 |         |  |               |
+                 |         |  +---------------+
+                 |         |       /|\
+                 |         |        |
+                 |         |        |
+                 |        \|/       |
+  WQE - 128 -----+--> +-------------+-------+     -+-
+                 |    |    *skb ----+       |      |
+                 |    |                     |      |
+                 |    |                     |      |
+                 |    |                     |      |
+                 |    |                     |      LATER_SKIP = 128
+                 |    |                     |      |
+                 |    |                     |      |
+                 |    |                     |      |
+                 |    +---------------------+     -+-
+                 |    |  packet link        |
+                 +--> |  packet data        |
+                      |                     |
+                      |                     |
+                      |         .           |
+                      |         .           |
+                      |         .           |
+                      +---------------------+
+ */
