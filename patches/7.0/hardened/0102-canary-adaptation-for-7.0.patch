+	 *
+	 * We only instrument objects that has not already been instrumented in `slab_free_hook()`.
 	 */
-	if (to_sheaf && canary) {
-		check_canary(s, object, s->sheaf_random_active);
-		set_canary(s, object, s->random_inactive);
-	}
