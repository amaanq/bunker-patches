 		__slab_free(s, slab, x, x, 1, _THIS_IP_);
 		stat(s, FREE_SLOWPATH);
 	}
@@ -6332,41 +6318,34 @@ void slab_free(struct kmem_cache *s, struct slab *slab, void *object,
 	       unsigned long addr)
 {
 	bool canary = true;
-	bool to_sheaf = false;
 
 	memcg_slab_free_hook(s, slab, &object, 1);
 	alloc_tagging_slab_free_hook(s, slab, &object, 1);
 
 	/* Make sure canaries are not used on kfence objects. */
-	if (is_kfence_address(object))
-		canary = false;
-
 	/* Defer canary checking if the object is freed back to pcs. */
-	if (cache_has_sheaves(s) && likely(!IS_ENABLED(CONFIG_NUMA) ||
-				     slab_nid(slab) == numa_mem_id())
-			   && likely(!slab_test_pfmemalloc(slab))) {
+	if (is_kfence_address(object) || cache_has_sheaves(s))
 		canary = false;
-	}
 
 	if (unlikely(!slab_free_hook(s, object, slab_want_init_on_free(s), false, canary)))
 		return;
 
 	if (likely(!IS_ENABLED(CONFIG_NUMA) || slab_nid(slab) == numa_mem_id())
 	    && likely(!slab_test_pfmemalloc(slab))) {
-		to_sheaf = true;
 		if (likely(free_to_pcs(s, object, true)))
 			return;
 	}
 
