From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Daniel Micay <danielmicay@gmail.com>
Date: Sun, 12 Apr 2026 00:00:00 -0400
Subject: [PATCH] mm: slub: only instrument slab allocation with canaries

Port of the linux-hardened bulk canary instrumentation for 7.0.

7.0-specific fixes:
 - refill_sheaf(): transition canary inactive->active after
   refill_objects() — 7.0 refills sheaves via refill_objects() not
   __kmem_cache_alloc_bulk(), so objects enter sheaves with inactive
   canary and every subsequent flush/check path BUG_ONs.
 - slab_free(): use cache_has_sheaves(s) instead of s->cpu_sheaves
   for the PCS canary bypass — 7.0 always allocates cpu_sheaves.
 - slab_free(): transition canary when free_to_pcs() fails.
 - obj_exts_offset_in_object(): account for canary word.
 - alloc_from_pcs() is unconditional in 7.0.
 - Two new sheaf_flush_unused() call sites + forward declaration.

Signed-off-by: Daniel Micay <danielmicay@gmail.com>
---
 mm/slub.c | 29 hunks
--- a/mm/slub.c
+++ b/mm/slub.c
@@ -786,9 +786,21 @@
 	unsigned long *canary = get_canary(s, object);
 	BUG_ON(*canary != get_canary_value(canary, value));
 }
+
+static inline void check_set_canary_bulk(struct kmem_cache *s, unsigned int size, void **objects, unsigned long check_value, unsigned long set_value)
+{
+	for (int i = 0; i < size; i++) {
+		if (!is_kfence_address(objects[i])) {
+			check_canary(s, objects[i], check_value);
+			set_canary(s, objects[i], set_value);
+		}
+	}
+}
+
 #else
 #define set_canary(s, object, value)
 #define check_canary(s, object, value)
+#define check_set_canary_bulk(s, size, objects, check_value, set_value)
 #endif
 
 #ifdef CONFIG_SLAB_OBJ_EXT
@@ -903,6 +915,9 @@
 {
 	unsigned int offset = get_info_end(s);
 
+	if (IS_ENABLED(CONFIG_SLAB_CANARY))
+		offset += sizeof(void *);
+
 	if (kmem_cache_debug_flags(s, SLAB_STORE_USER))
 		offset += sizeof(struct track) * 2;
 
@@ -2888,6 +2903,8 @@
 	filled = refill_objects(s, &sheaf->objects[sheaf->size], gfp, to_fill,
 				to_fill);
 
+	check_set_canary_bulk(s, filled, &sheaf->objects[sheaf->size], s->random_inactive, s->random_active);
+
 	sheaf->size += filled;
 
 	stat_add(s, SHEAF_REFILL, filled);
@@ -2898,7 +2915,7 @@
 	return 0;
 }
 
-static void sheaf_flush_unused(struct kmem_cache *s, struct slab_sheaf *sheaf);
+static void sheaf_flush_unused(struct kmem_cache *s, struct slab_sheaf *sheaf, bool canary);
 
 static struct slab_sheaf *alloc_full_sheaf(struct kmem_cache *s, gfp_t gfp)
 {
@@ -2908,7 +2925,7 @@
 		return NULL;
 
 	if (refill_sheaf(s, sheaf, gfp | __GFP_NOMEMALLOC | __GFP_NOWARN)) {
-		sheaf_flush_unused(s, sheaf);
+		sheaf_flush_unused(s, sheaf, false);
 		free_empty_sheaf(s, sheaf);
 		return NULL;
 	}
@@ -2956,6 +2973,7 @@
 
 	local_unlock(&s->cpu_sheaves->lock);
 
+	check_set_canary_bulk(s, batch, &objects[0], s->random_active, s->random_inactive);
 	__kmem_cache_free_bulk(s, batch, &objects[0]);
 
 	stat_add(s, SHEAF_FLUSH, batch);
@@ -3001,18 +3019,48 @@
  * necessary when flushing cpu's sheaves (both spare and main) during cpu
  * hotremove as the cpu is not executing anymore.
  */
-static void sheaf_flush_unused(struct kmem_cache *s, struct slab_sheaf *sheaf)
+static void sheaf_flush_unused(struct kmem_cache *s, struct slab_sheaf *sheaf, bool canary)
 {
 	if (!sheaf->size)
 		return;
 
 	stat_add(s, SHEAF_FLUSH, sheaf->size);
 
+	if (canary)
+		check_set_canary_bulk(s, sheaf->size, &sheaf->objects[0], s->random_active, s->random_inactive);
 	__kmem_cache_free_bulk(s, sheaf->size, &sheaf->objects[0]);
 
 	sheaf->size = 0;
 }
 
+static bool __rcu_free_sheaf_prepare_nocanary(struct kmem_cache *s,
+				     struct slab_sheaf *sheaf)
+{
+	bool init = slab_want_init_on_free(s);
+	void **p = &sheaf->objects[0];
+	unsigned int i = 0;
+	bool pfmemalloc = false;
+
+	while (i < sheaf->size) {
+		struct slab *slab = virt_to_slab(p[i]);
+
+		memcg_slab_free_hook(s, slab, p + i, 1);
+		alloc_tagging_slab_free_hook(s, slab, p + i, 1);
+
+		if (unlikely(!slab_free_hook(s, p[i], init, true, false))) {
+			p[i] = p[--sheaf->size];
+			continue;
+		}
+
+		if (slab_test_pfmemalloc(slab))
+			pfmemalloc = true;
+
+		i++;
+	}
+
+	return pfmemalloc;
+}
+
 static bool __rcu_free_sheaf_prepare(struct kmem_cache *s,
 				     struct slab_sheaf *sheaf)
 {
@@ -3027,7 +3075,7 @@
 		memcg_slab_free_hook(s, slab, p + i, 1);
 		alloc_tagging_slab_free_hook(s, slab, p + i, 1);
 
-		if (unlikely(!slab_free_hook(s, p[i], init, true))) {
+		if (unlikely(!slab_free_hook(s, p[i], init, true, true))) {
 			p[i] = p[--sheaf->size];
 			continue;
 		}
@@ -3051,7 +3099,7 @@
 
 	__rcu_free_sheaf_prepare(s, sheaf);
 
-	sheaf_flush_unused(s, sheaf);
+	sheaf_flush_unused(s, sheaf, false);
 
 	free_empty_sheaf(s, sheaf);
 }
@@ -3082,7 +3130,7 @@
 	local_unlock(&s->cpu_sheaves->lock);
 
 	if (spare) {
-		sheaf_flush_unused(s, spare);
+		sheaf_flush_unused(s, spare, true);
 		free_empty_sheaf(s, spare);
 	}
 
@@ -3099,9 +3147,9 @@
 	pcs = per_cpu_ptr(s->cpu_sheaves, cpu);
 
 	/* The cpu is not executing anymore so we don't need pcs->lock */
-	sheaf_flush_unused(s, pcs->main);
+	sheaf_flush_unused(s, pcs->main, true);
 	if (pcs->spare) {
-		sheaf_flush_unused(s, pcs->spare);
+		sheaf_flush_unused(s, pcs->spare, true);
 		free_empty_sheaf(s, pcs->spare);
 		pcs->spare = NULL;
 	}
@@ -3340,7 +3388,7 @@
 	spin_unlock_irqrestore(&barn->lock, flags);
 
 	list_for_each_entry_safe(sheaf, sheaf2, &full_list, barn_list) {
-		sheaf_flush_unused(s, sheaf);
+		sheaf_flush_unused(s, sheaf, true);
 		free_empty_sheaf(s, sheaf);
 	}
 
@@ -4697,7 +4745,7 @@
 			 * we must be very low on memory so don't bother
 			 * with the barn
 			 */
-			sheaf_flush_unused(s, empty);
+			sheaf_flush_unused(s, empty, false);
 			free_empty_sheaf(s, empty);
 		}
 	} else {
@@ -4917,6 +4965,7 @@
 {
 	void *object;
 	bool init = false;
+	bool from_pcs = false;
 
 	s = slab_pre_alloc_hook(s, gfpflags);
 	if (unlikely(!s))
@@ -4928,6 +4977,9 @@
 
 	object = alloc_from_pcs(s, gfpflags, node);
 
+	if (object)
+		from_pcs = true;
+
 	if (!object)
 		object = __slab_alloc_node(s, gfpflags, node, addr, orig_size);
 
@@ -4946,7 +4998,7 @@
 		init = slab_want_init_on_alloc(gfpflags, s);
 	}
 
-	if (object) {
+	if (object && !from_pcs) {
 		check_canary(s, object, s->random_inactive);
 		set_canary(s, object, s->random_active);
 	}
@@ -5118,7 +5170,7 @@
 
 		if (sheaf->size < size &&
 		    __prefill_sheaf_pfmemalloc(s, sheaf, gfp)) {
-			sheaf_flush_unused(s, sheaf);
+			sheaf_flush_unused(s, sheaf, true);
 			free_empty_sheaf(s, sheaf);
 			sheaf = NULL;
 		}
@@ -5145,7 +5197,7 @@
 
 	if (unlikely((sheaf->capacity != s->sheaf_capacity)
 		     || sheaf->pfmemalloc)) {
-		sheaf_flush_unused(s, sheaf);
+		sheaf_flush_unused(s, sheaf, true);
 		kfree(sheaf);
 		return;
 	}
@@ -5173,7 +5225,7 @@
 	 */
 	if (!barn || data_race(barn->nr_full) >= MAX_FULL_SHEAVES ||
 	    refill_sheaf(s, sheaf, gfp)) {
-		sheaf_flush_unused(s, sheaf);
+		sheaf_flush_unused(s, sheaf, true);
 		free_empty_sheaf(s, sheaf);
 		return;
 	}
@@ -5790,7 +5842,7 @@
 		pcs->spare = NULL;
 		local_unlock(&s->cpu_sheaves->lock);
 
-		sheaf_flush_unused(s, to_flush);
+		sheaf_flush_unused(s, to_flush, true);
 		empty = to_flush;
 		goto got_empty;
 	}
@@ -5903,7 +5955,7 @@
 	 * If it returns true, there was at least one object from pfmemalloc
 	 * slab so simply flush everything.
 	 */
-	if (__rcu_free_sheaf_prepare(s, sheaf))
+	if (__rcu_free_sheaf_prepare_nocanary(s, sheaf))
 		goto flush;
 
 	n = get_node(s, sheaf->node);
@@ -5930,7 +5982,7 @@
 
 flush:
 	stat(s, BARN_PUT_FAIL);
-	sheaf_flush_unused(s, sheaf);
+	sheaf_flush_unused(s, sheaf, true);
 
 empty:
 	if (barn && data_race(barn->nr_empty) < MAX_EMPTY_SHEAVES) {
@@ -6078,7 +6130,7 @@
 		memcg_slab_free_hook(s, slab, p + i, 1);
 		alloc_tagging_slab_free_hook(s, slab, p + i, 1);
 
-		if (unlikely(!slab_free_hook(s, p[i], init, false))) {
+		if (unlikely(!slab_free_hook(s, p[i], init, false, false))) {
 			p[i] = p[--size];
 			continue;
 		}
@@ -6165,11 +6217,13 @@
 	 * many full sheaves, free the rest to slab pages
 	 */
 fallback:
+	check_set_canary_bulk(s, size, p, s->random_active, s->random_inactive);
 	__kmem_cache_free_bulk(s, size, p);
 	stat_add(s, FREE_SLOWPATH, size);
 
 flush_remote:
 	if (remote_nr) {
+		check_set_canary_bulk(s, remote_nr, &remote_objects[0], s->random_active, s->random_inactive);
 		__kmem_cache_free_bulk(s, remote_nr, &remote_objects[0]);
 		stat_add(s, FREE_SLOWPATH, remote_nr);
 		if (i < size) {
@@ -6263,6 +6317,13 @@
 	if (is_kfence_address(object))
 		canary = false;
 
+	/* Do not check or set canary if the object is freed back to pcs. */
+	if (cache_has_sheaves(s) && likely(!IS_ENABLED(CONFIG_NUMA) ||
+				     slab_nid(slab) == numa_mem_id())
+			   && likely(!slab_test_pfmemalloc(slab))) {
+		canary = false;
+	}
+
 	if (unlikely(!slab_free_hook(s, object, slab_want_init_on_free(s), false, canary)))
 		return;
 
@@ -6272,6 +6333,11 @@
 			return;
 	}
 
+
+	/* PCS free failed — transition canary for slab freelist */
+	if (canary && !is_kfence_address(object))
+		set_canary(s, object, s->random_inactive);
+
 	__slab_free(s, slab, object, object, 1, addr);
 	stat(s, FREE_SLOWPATH);
 }
@@ -7315,7 +7381,7 @@
