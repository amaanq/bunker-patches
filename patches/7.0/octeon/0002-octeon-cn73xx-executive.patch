+			     "bootmem descriptor!\n");
+		return 0;
+	}
+	for (i = 0; i < CVMX_BOOTMEM_NUM_NAMED_BLOCKS; i++) {
+		CVMX_BOOTMEM_NAMED_SET_FIELD(addr, base_addr, 0);
+		CVMX_BOOTMEM_NAMED_SET_FIELD(addr, size, 0);
+		addr += sizeof(cvmx_bootmem_named_block_desc_t);
+	}
+
+	return 1;
+}
