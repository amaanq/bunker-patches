+		return __get_generic_8023_c45_phy_link_state(phy_info);
+
+	phy_status = cvmx_mdio_45_read(phy_addr >> 8, phy_addr & 0xff,
+				       3, 0xe10d);
+
+	result.u64 = 0;
+	if ((phy_status & 0x111) != 0x111)
+		return result;
