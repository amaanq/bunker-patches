+		return (node << 1) | bus;
+	else
+		return bus;
+}
+#endif
+
+static int i2c_bus_to_node(int i2c_bus)
+{
+	if (octeon_has_feature(OCTEON_FEATURE_MULTINODE))
+		return (i2c_bus >> 1) & 0x3;
+	else
+		return 0;
+}
+
+static int __i2c_twsi_bus(int i2c_bus)
+{
+	if (octeon_has_feature(OCTEON_FEATURE_MULTINODE))
+		return i2c_bus & 0x1;
+	else
+		return i2c_bus;
