+		cvmx_write_csr(CVMX_GMXX_TX_INT_REG(interface), ~0x0ull);
+		cvmx_write_csr(CVMX_PCSXX_INT_REG(interface), ~0x0ull);
+
+		/* Disable GMX enable override */
+		misc_ctl.u64 = cvmx_read_csr(CVMX_PCSXX_MISC_CTL_REG(interface));
