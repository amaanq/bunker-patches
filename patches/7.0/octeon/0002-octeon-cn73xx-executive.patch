+#ifdef __OPTIMIZE_SIZE__
+#ifndef CVMX_BUILD_FOR_LINUX_KERNEL
+int __octeon_is_model_runtime__(uint32_t model)
+{
+	return __octeon_is_model_runtime_internal__(model);
+}
