+int init_cvmx_pko_que_range(void)
+{
+	int rv = 0;
+
+	if (queue_range_init)
+		return 0;
+	queue_range_init = 1;
+	rv = cvmx_create_global_resource_range(CVMX_GR_TAG_PKO_QUEUES, CVMX_HELPER_CFG_MAX_PKO_QUEUES);
+	if (rv!=0) {
+		cvmx_printf("ERROR: %s: Failed to initalize pko queues range\n",
+			__func__);
+	}
+	return rv;
+}
