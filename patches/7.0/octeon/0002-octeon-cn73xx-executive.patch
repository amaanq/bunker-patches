+	gmx_cfg.s.en = 0;
+	cvmx_write_csr(CVMX_GMXX_PRTX_CFG(0, interface), gmx_cfg.u64);
+
+	/* This call doesn't properly disable GMX despite its comment
+	 * It waits for GMX to appear idle
