+static int __mdiobus_addr_to_unit(uint32_t addr)
+{
+	int unit = (addr >> 7) & 3;
+	if (!OCTEON_IS_MODEL(OCTEON_CN68XX) && !OCTEON_IS_MODEL(OCTEON_CN78XX))
+		unit >>= 1;
+	return unit;
+}
