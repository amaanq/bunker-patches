+/* Mainline 6.18's i2c-octeon driver does not export octeon_i2c_cvmx2i2c
+ * (the EdgeOS-specific routine that mapped a CVMX TWSI bus number onto a
+ * Linux I2C adapter index). The CN73XX BGX/PHY path on the EdgeRouter
+ * Infinity does not need MAC-address-via-EEPROM lookup, so stub the
+ * mapping function and let cvmx_twsix_open() return NULL. The kernel
+ * twsi_open() callers all check for NULL and fall back to non-EEPROM
+ * paths; nothing here regresses for our target. */
+__attribute__((weak)) int octeon_i2c_cvmx2i2c(unsigned int twsi)
+{
+	return -ENXIO;
+}
+
+#else /* #ifdef CVMX_BUILD_FOR_LINUX_KERNEL */
+
+#include <asm/octeon/cvmx.h>
+#include <asm/octeon/cvmx-twsi.h>
